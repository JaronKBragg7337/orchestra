{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JaronKBragg7337/orchestra/schemas/comparison.schema.json",
  "title": "Orchestra synthesis comparison",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cycle_date", "synthesis_context", "items"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "cycle_date": { "type": "string", "format": "date" },
    "synthesis_context": {
      "type": "object",
      "required": ["a", "b"],
      "additionalProperties": false,
      "properties": {
        "a": { "$ref": "#/$defs/context" },
        "b": { "$ref": "#/$defs/context" }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["comparison_id", "state", "synthesis_a_items", "synthesis_b_items", "rationale"],
        "properties": {
          "comparison_id": { "type": "string", "pattern": "^cmp-[0-9]{8}-[0-9]{3}$" },
          "state": {
            "enum": [
              "INDEPENDENT_CONVERGENT",
              "INFORMED_CONVERGENT",
              "INDEPENDENT_DIVERGENT",
              "INFORMED_DIVERGENT",
              "ASYMMETRIC",
              "SUSPECT"
            ]
          },
          "synthesis_a_items": { "type": "array", "items": { "type": "string" } },
          "synthesis_b_items": { "type": "array", "items": { "type": "string" } },
          "rationale": { "type": "string", "minLength": 1 },
          "signal_id": { "type": ["string", "null"], "pattern": "^ORC-[0-9]{8}-[0-9]{3}$" }
        }
      }
    }
  },
  "$defs": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read_captures", "read_prior_synthesis", "read_tracker", "read_prior_readings", "read_prompts", "other_context"],
      "properties": {
        "read_captures": { "const": true },
        "read_prior_synthesis": { "type": ["string", "null"] },
        "read_tracker": { "type": "boolean" },
        "read_prior_readings": { "type": ["string", "null"] },
        "read_prompts": { "type": "boolean" },
        "other_context": { "type": ["string", "null"] }
      }
    }
  }
}
